rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo permite acceso si el usuario está autenticado y su UID coincide
    // con el administrador configurado en NEXT_PUBLIC_AUTHORIZED_UID.
    // Cambia 'EL_UID_DE_LA_DUEÑA' por el UID real antes de desplegar.
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == 'EL_UID_DE_LA_DUEÑA';
    }
  }
}
